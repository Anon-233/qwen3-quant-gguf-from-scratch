# AI assistant / agent files
#
# Keep shareable project instructions in git when present:
#   AGENTS.md, CLAUDE.md
#   .codex/**/*.md, .codex/**/*.json
#   .claude/**/*.md, .claude/**/*.json
#
# Ignore only local state, secrets, sessions, caches, and machine-specific
# settings. This keeps Codex / Claude Code project guidance versioned without
# publishing personal assistant history or credentials.
.codex/sessions/
.codex/logs/
.codex/cache/
.codex/tmp/
.codex/local/
.codex/history/
.codex/**/*.local.*
.codex/**/settings.local.*
.codex/**/.env
.codex/**/.env.*

.claude/settings.local.json
.claude/**/settings.local.json
.claude/logs/
.claude/cache/
.claude/tmp/
.claude/projects/
.claude/todos/
.claude/history/
.claude/**/*.local.*
.claude/**/.env
.claude/**/.env.*

.claude.json
CLAUDE.local.md
AGENTS.local.md
.mcp.local.json
.mcp.*.local.json

# Local caches
.cache/
.huggingface/
wandb/

# Large generated artifacts
*.gguf
*.safetensors
*.bin
*.pt
*.pth
